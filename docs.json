{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "MoltSets API Documentation",
  "colors": {
    "primary": "#F4805D",
    "light": "#F4805D",
    "dark": "#312825"
  },
  "css": "/custom.css",
  "favicon": "/logo/favicon.png",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "mdx": {
      "server": "https://api.moltsets.com/api/v1/tools/",
      "auth": {
        "method": "bearer",
        "name": "Authorization Bearer"
      },
      "url": "full"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      },
      {
        "tab": "Guide",
        "pages": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/overview",
              "getting-started/authentication",
              "getting-started/rate-limits",
              "getting-started/moltsets-app"
            ]
          },
          {
            "group": "Use Cases",
            "pages": [
              "use-cases/i-have-x-i-want-y",
              "use-cases/find-companies-and-contacts"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/moltsets-mcp",
              "integrations/clay"
            ]
          }
        ]
      }
      
    ]
  },
  "logo": "/logo/moltsets.png",
  "navbar": {
    "links": [
      {
        "label": "Login / Sign Up",
        "href": "https://app.moltsets.com"
      },
      {
        "label": "Support Docs",
        "href": "https://support.moltsets.com"
      },
      {
        "label": "Skills Library",
        "href": "https://library.moltsets.com"
      },
      {
        "label": "Earn 20% Commission",
        "href": "https://affiliates.moltsets.com"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/moltsets"
    }
  },
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#e4e8f0"
    }
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-W24PWQ91SP"
    }
  }
}