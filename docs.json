{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "MoltSets API Documentation",
  "colors": {
    "primary": "#F4805D",
    "light": "#F4805D",
    "dark": "#312825"
  },
  "css": "/custom.css",
  "favicon": "/logo/favicon.png",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "mdx": {
      "server": "https://api.moltsets.com/api/v1/tools/",
      "auth": {
        "method": "bearer",
        "name": "Authorization Bearer"
      },
      "url": "full"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guide",
        "pages": [
          {
            "group": "Getting Started",
            "pages": [
              "developer-docs/getting-started/authentication",
              "developer-docs/getting-started/overview",
              "developer-docs/getting-started/rate-limits",
              {
                "group": "Account",
                "pages": [
                  "using-the-moltsets-app",
                  "plans"
                ]
              }
            ]
          },
          {
            "group": "Use Cases",
            "pages": [
              "i-have-x-i-want-y"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "moltsets-mcp"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ]
  },
  "logo": "/logo/moltsets.png",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#e4e8f0"
    }
  }
}